function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function showStudyMode() {
  showScreen('studyScreen');
  document.getElementById('categorySelection').style.display = 'block';
  document.getElementById('flashcardContainer').style.display = 'none';
}

function toggleStudyMode() {
  isAIMode = !isAIMode;
  const toggle = document.getElementById('modeToggle');
  const curatedLabel = document.getElementById('curatedLabel');
  const aiLabel = document.getElementById('aiLabel');
  const aiInfo = document.getElementById('aiModeInfo');
  const startBtn = document.getElementById('startStudyBtn');
  
  if (isAIMode) {
    toggle.classList.add('ai-mode');
    curatedLabel.classList.remove('active');
    aiLabel.classList.add('active');
    aiInfo.style.display = 'block';
    startBtn.textContent = 'Generate AI Deck ✨';
    startBtn.classList.add('generate-btn');
  } else {
    toggle.classList.remove('ai-mode');
    curatedLabel.classList.add('active');
    aiLabel.classList.remove('active');
    aiInfo.style.display = 'none';
    startBtn.textContent = 'Start Studying';
    startBtn.classList.remove('generate-btn');
  }
}

function selectCategory(cat) {
  selectedCategory = cat;
  document.querySelectorAll('#categorySelect .diff-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
}

function startStudying() {
  if (isAIMode) {
    generateDeck();
  } else {
    loadCuratedDeck();
  }
}

function loadCuratedDeck() {
  studyDeck = [...curatedFlashcards[selectedCategory]];
  currentCard = 0;
  
  document.getElementById('categorySelection').style.display = 'none';
  document.getElementById('flashcardContainer').style.display = 'block';
  document.getElementById('shuffleBtn').style.display = 'inline-block';
  document.getElementById('generateMoreBtn').style.display = 'none';
  
  renderFlashcard();
}

