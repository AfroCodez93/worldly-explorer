// Update stats display on main menu
function updateStatsDisplay() {
  document.getElementById('streakNumber').textContent = userProgress.dailyStreakCount;
  document.getElementById('achievementCount').textContent = `${userProgress.achievements.length}/${ACHIEVEMENTS.length}`;
  
  const totalAnswered = userProgress.totalQuestionsAnswered;
  const accuracy = totalAnswered > 0 ? Math.round((userProgress.totalCorrectAnswers / totalAnswered) * 100) : 0;
