// ─── WORLD TOUR FUNCTIONS ────────────────────────────────────────
function showWorldTour() {
  showScreen('worldTourScreen');
  renderCountries();
  updateCountriesVisited();
}

function selectContinent(continent) {
  selectedContinent = continent;
  document.querySelectorAll('.continent-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  renderCountries();
}

function renderCountries() {
  const grid = document.getElementById('countriesGrid');
  grid.innerHTML = '';
  
  const continentCountries = countries[selectedContinent];
  continentCountries.forEach(country => {
    const isVisited = userProgress.visitedCountries.includes(country.name);
    
    const card = document.createElement('div');
    card.className = `country-card ${isVisited ? 'visited' : ''}`;
    card.onclick = () => isVisited ? showCountryFacts(country) : startCountryChallenge(country);
    card.innerHTML = `
      <div class="country-card-flag">${country.flag}</div>
      <div class="country-card-name">${country.name}</div>
      <div class="country-card-status">${isVisited ? '✓ Visited — tap to revisit' : 'Not visited'}</div>
    `;
    grid.appendChild(card);
  });
}

function updateCountriesVisited() {
  const total = Object.values(countries).reduce((sum, continent) => sum + continent.length, 0);
  document.getElementById('countriesVisited').textContent = `${userProgress.visitedCountries.length}/${total}`;
}

function startCountryChallenge(country) {
  currentCountry = country;
  countryQuestionIndex = 0;
  countryCorrectAnswers = 0;
  
  document.getElementById('countryFlag').textContent = country.flag;
  document.getElementById('countryName').textContent = country.name;
  
  showScreen('countryChallenge');
  renderCountryQuestion();
}

function renderCountryQuestion() {
  // Filter geography questions about this region
  const regionQuestions = allQuizQuestions.filter(q => 
    q.category === 'Geography' && !askedQuestions.includes(q.question)
  );
  
  if (regionQuestions.length === 0) {
    // Fallback to any question
    const anyQuestion = allQuizQuestions.filter(q => !askedQuestions.includes(q.question))[0];
    displayCountryQuestion(anyQuestion);
  } else {
    const randomQ = regionQuestions[Math.floor(Math.random() * regionQuestions.length)];
    displayCountryQuestion(randomQ);
  }
}

function displayCountryQuestion(q) {
  document.getElementById('countryQuestionText').textContent = q.question;
  document.getElementById('countryProgress').textContent = `${countryCorrectAnswers}/3`;
  
  const grid = document.getElementById('countryOptionsGrid');
  grid.innerHTML = '';
  const letters = ['A', 'B', 'C', 'D'];
  
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-letter">${letters[i]}</span>${opt}`;
    btn.onclick = () => selectCountryAnswer(i, q);
    grid.appendChild(btn);
  });
  
  document.getElementById('countryFeedback').className = 'feedback';
  document.getElementById('countryNextBtn').className = 'next-btn';
  
  askedQuestions.push(q.question);
}

function selectCountryAnswer(idx, q) {
  const btns = document.querySelectorAll('#countryOptionsGrid .option-btn');
  const isCorrect = idx === q.answer;
  
  btns.forEach(b => b.disabled = true);
  btns[idx].classList.add(isCorrect ? 'correct' : 'wrong');
  
  if (!isCorrect) {
    btns[q.answer].classList.add('reveal');
  }
  
  const fb = document.getElementById('countryFeedback');
  fb.className = `feedback ${isCorrect ? 'correct-fb' : 'wrong-fb'} show`;
  fb.innerHTML = `<span class="feedback-icon">${isCorrect ? '🌟' : '📖'}</span><span>${q.explanation}</span>`;
  
  if (isCorrect) {
    countryCorrectAnswers++;
    document.getElementById('countryProgress').textContent = `${countryCorrectAnswers}/3`;
  }
  
  document.getElementById('countryNextBtn').className = 'next-btn show';
}

function nextCountryQuestion() {
  if (countryCorrectAnswers >= 3) {
    // Country unlocked!
    if (!userProgress.visitedCountries.includes(currentCountry.name)) {
      userProgress.visitedCountries.push(currentCountry.name);
      saveProgress();
      checkAchievements();
    }
    
    // Show country facts screen
    showCountryFacts(currentCountry);
  } else {
    countryQuestionIndex++;
    renderCountryQuestion();
  }
}

function showCountryFacts(country, isRevisit = false) {
  showScreen('countryFactsScreen');
  
  const isAlreadyVisited = userProgress.visitedCountries.includes(country.name);
  const revisiting = isRevisit || isAlreadyVisited;

  // Adapt header copy based on first unlock vs revisit
  document.getElementById('unlockedFlag').textContent = country.flag;
  document.getElementById('unlockedCountryName').textContent = country.name;
  document.getElementById('unlockedCountryName2').textContent = country.name;
  document.getElementById('factsScreenLabel').textContent = revisiting ? 'Revisiting' : 'Unlocked!';
  document.getElementById('factsScreenTitle').textContent = revisiting ? `📖 Welcome back to ${country.name}!` : '🎉 Congratulations!';
  document.getElementById('factsScreenSubtitle').innerHTML = revisiting
    ? `Here are your unlocked facts about <span>${country.name}</span>`
    : `You've unlocked <span>${country.name}</span>`;

  // Populate facts
  const factsList = document.getElementById('countryFactsList');
  factsList.innerHTML = '';
  
  const factIcons = ['🌟', '📍', '🎯', '💡', '🏛️', '🌍', '✨'];
  
  country.facts.forEach((fact, index) => {
    const factItem = document.createElement('div');
    factItem.className = 'fact-item';
    factItem.innerHTML = `
      <div class="fact-icon">${factIcons[index % factIcons.length]}</div>
      <div class="fact-text">${fact}</div>
