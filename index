// ─── DIFFICULTY ADAPTATION ───────────────────────────────────────
function updatePerformance(correct, responseTime) {
  performanceHistory.push({
    correct: correct,
    time: responseTime,
    timestamp: Date.now()
  });
  
  // Keep only last 5 questions
  if (performanceHistory.length > 5) {
    performanceHistory.shift();
  }
  
  // Adapt difficulty if we have enough data
  if (performanceHistory.length >= 3) {
    adaptDifficulty();
  }
}

function adaptDifficulty() {
  const recentPerformance = performanceHistory.slice(-3);
  const correctCount = recentPerformance.filter(p => p.correct).length;
  const avgTime = recentPerformance.reduce((sum, p) => sum + p.time, 0) / recentPerformance.length;
  
  // Increase difficulty if: 3/3 correct AND average time > 10s
  if (correctCount === 3 && avgTime > 10) {
    if (currentAdaptiveLevel === 'easy') {
      currentAdaptiveLevel = 'medium';
      console.log('Difficulty increased to MEDIUM');
    } else if (currentAdaptiveLevel === 'medium') {
      currentAdaptiveLevel = 'hard';
      console.log('Difficulty increased to HARD');
    }
  }
  
  // Decrease difficulty if: 0/3 correct OR 1/3 correct
  else if (correctCount <= 1) {
    if (currentAdaptiveLevel === 'hard') {
      currentAdaptiveLevel = 'medium';
      console.log('Difficulty decreased to MEDIUM');
    } else if (currentAdaptiveLevel === 'medium') {
      currentAdaptiveLevel = 'easy';
      console.log('Difficulty decreased to EASY');
    }
  }
}

function getAdaptiveQuestion() {
  let pool;
  if (currentAdaptiveLevel === 'easy') {
    pool = allQuizQuestions.filter(q => q.difficulty === 'easy');
  } else if (currentAdaptiveLevel === 'hard') {
    pool = allQuizQuestions.filter(q => q.difficulty === 'hard');
  } else {
    pool = allQuizQuestions.filter(q => q.difficulty === 'medium');
  }
  
  // Fallback to all questions if pool is empty
  if (pool.length === 0) pool = allQuizQuestions;
  
  // Filter out questions already asked
  const availableQuestions = pool.filter(q => !askedQuestions.includes(q.question));
  
  // If all questions from this difficulty have been asked, use any unasked question
  if (availableQuestions.length === 0) {
    const anyUnasked = allQuizQuestions.filter(q => !askedQuestions.includes(q.question));
    if (anyUnasked.length > 0) {
      const selected = anyUnasked[Math.floor(Math.random() * anyUnasked.length)];
      askedQuestions.push(selected.question);
      return selected;
    }
    // If somehow all questions asked (shouldn't happen in a 10-question game), reset
    askedQuestions = [];
    const selected = pool[Math.floor(Math.random() * pool.length)];
    askedQuestions.push(selected.question);
    return selected;
  }
  
  const selected = availableQuestions[Math.floor(Math.random() * availableQuestions.length)];
  askedQuestions.push(selected.question);
  return selected;
}
