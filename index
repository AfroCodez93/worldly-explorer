          {
            role: "user",
            content: prompts[selectedCategory]
          }
        ],
        tools: [
          {
            type: "web_search_20250305",
            name: "web_search"
          }
        ]
      })
    });

    if (!response.ok) {
      throw new Error(`API error: ${response.status}`);
    }

    const data = await response.json();
    
    let jsonText = '';
    for (const block of data.content) {
      if (block.type === 'text') {
        jsonText += block.text;
      }
    }

    jsonText = jsonText.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
    const cards = JSON.parse(jsonText);
    
    if (!Array.isArray(cards) || cards.length === 0) {
      throw new Error('Invalid response format');
    }

    studyDeck = cards;
    currentCard = 0;
    
    document.getElementById('categorySelection').style.display = 'none';
    document.getElementById('flashcardContainer').style.display = 'block';
    document.getElementById('shuffleBtn').style.display = 'none';
    document.getElementById('generateMoreBtn').style.display = 'inline-block';
    
    renderFlashcard();

  } catch (error) {
    console.error('Generation error:', error);
    alert('Failed to generate flashcards. Please try again. Error: ' + error.message);
  } finally {
    btn.disabled = false;
    btn.innerHTML = originalText;
  }
}

function renderFlashcard() {
  if (studyDeck.length === 0) return;
  
  const card = studyDeck[currentCard];
  document.getElementById('cardFront').textContent = card.front;
  document.getElementById('cardBack').textContent = card.back;
  document.getElementById('cardCategory').textContent = card.category || '';
  document.getElementById('cardSource').textContent = card.source ? `Source: ${card.source}` : '';
  document.getElementById('studyProgress').textContent = `${currentCard + 1}/${studyDeck.length}`;
  
  document.getElementById('flashcardInner').classList.remove('flipped');
  isFlipped = false;
  
  document.getElementById('prevBtn').disabled = currentCard === 0;
  document.getElementById('nextBtn').disabled = currentCard === studyDeck.length - 1;
}

function flipCard() {
  const inner = document.getElementById('flashcardInner');
  const wasFlipped = isFlipped;
  inner.classList.toggle('flipped');
  isFlipped = !isFlipped;
  
  // Track when card is flipped to back (studying)
  if (!wasFlipped && isFlipped) {
    trackStudyCard();
  }
}

function nextCard() {
  if (currentCard < studyDeck.length - 1) {
    currentCard++;
    renderFlashcard();
  }
}

function prevCard() {
  if (currentCard > 0) {
    currentCard--;
    renderFlashcard();
  }
}

function shuffleDeck() {
  studyDeck = studyDeck.sort(() => Math.random() - 0.5);
  currentCard = 0;
  renderFlashcard();
}

function backToCategorySelect() {
  document.getElementById('categorySelection').style.display = 'block';
  document.getElementById('flashcardContainer').style.display = 'none';
}

// ─── QUIZ GAME FUNCTIONS ─────────────────────────────────────────
function setDiff(d) {
  quizDifficulty = d;
  document.querySelectorAll('#startScreen .diff-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
}

function pickQuizQuestions() {
  let pool;
  
  // Check if adaptive mode should be enabled (mixed difficulty)
  if (quizDifficulty === 'mixed') {
    adaptiveDifficulty = true;
    currentAdaptiveLevel = 'medium'; // Start at medium
    performanceHistory = [];
    
    // Build adaptive question set
    const questions = [];
    for (let i = 0; i < TOTAL_Q; i++) {
      const question = getAdaptiveQuestion();
      questions.push(question);
    }
    return questions;
  } else {
    adaptiveDifficulty = false;
    
    if (quizDifficulty === 'easy') pool = allQuizQuestions.filter(q => q.difficulty === 'easy');
    else if (quizDifficulty === 'hard') pool = allQuizQuestions.filter(q => q.difficulty === 'hard' || q.difficulty === 'medium');
    else pool = [...allQuizQuestions];

    const shuffled = pool.sort(() => Math.random() - 0.5);
    const selected = shuffled.slice(0, Math.min(TOTAL_Q, shuffled.length));
    
    // Track these questions as asked
    selected.forEach(q => askedQuestions.push(q.question));
    
    return selected;
  }
}

function startGame() {
  quizQuestions = pickQuizQuestions();
  currentQuestion = 0; 
  quizScore = 0; 
  quizStreak = 0; 
  bestQuizStreak = 0; 
  correctAnswers = 0;
  askedQuestions = []; // Reset question tracking
  showScreen('gameScreen');
  updateQuizStats();
  renderQuizQuestion();
}

function renderQuizQuestion() {
  answered = false;
  
  // For adaptive mode, get next question dynamically
  if (adaptiveDifficulty && currentQuestion > 0) {
    quizQuestions[currentQuestion] = getAdaptiveQuestion();
  }
  
  const q = quizQuestions[currentQuestion];
  const area = document.getElementById('questionArea');

  area.style.animation = 'none';
  area.offsetHeight;
  area.style.animation = '';

  document.getElementById('questionCounter').textContent = `Question ${currentQuestion + 1} of ${quizQuestions.length}`;
  document.getElementById('categoryLabel').textContent = q.category;
  document.getElementById('questionText').textContent = q.question;
  document.getElementById('questionHint').textContent = q.hint ? `💡 ${q.hint}` : '';

  const grid = document.getElementById('optionsGrid');
  grid.innerHTML = '';
  const letters = ['A', 'B', 'C', 'D'];

  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-letter">${letters[i]}</span>${opt}`;
    btn.onclick = () => selectQuizAnswer(i);
    grid.appendChild(btn);
  });

  const fb = document.getElementById('feedback');
  fb.className = 'feedback';
  fb.style.opacity = '0';
  document.getElementById('nextBtn').className = 'next-btn';

  document.getElementById('progressFill').style.width = `${(currentQuestion / quizQuestions.length) * 100}%`;

  startQuizTimer();
}

function startQuizTimer() {
  clearInterval(timerInterval);
  timeLeft = TIME_LIMIT;
  updateTimerDisplay();
  timerInterval = setInterval(() => {
    timeLeft--;
    updateTimerDisplay();
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      if (!answered) timeUp();
    }
  }, 1000);
}

function updateTimerDisplay() {
  document.getElementById('timerText').textContent = timeLeft;
  const ring = document.getElementById('timerRing');
  const circumference = 138;
  const offset = circumference * (1 - timeLeft / TIME_LIMIT);
  ring.style.strokeDashoffset = offset;
  ring.style.stroke = timeLeft > 8 ? 'var(--gold)' : timeLeft > 4 ? '#e07a20' : 'var(--crimson)';
}

function timeUp() {
  answered = true;
  quizStreak = 0;
  updateQuizStats();
  revealQuizAnswer();
  showQuizFeedback(false, `⏰ Time's up! The correct answer was: <strong>${quizQuestions[currentQuestion].options[quizQuestions[currentQuestion].answer]}</strong>. ${quizQuestions[currentQuestion].explanation}`);
  document.getElementById('nextBtn').className = 'next-btn show';
}

function selectQuizAnswer(idx) {
  if (answered) return;
  answered = true;
  const responseTime = TIME_LIMIT - timeLeft; // How long they took
  clearInterval(timerInterval);

  const q = quizQuestions[currentQuestion];
  const btns = document.querySelectorAll('.option-btn');
  const isCorrect = idx === q.answer;

  btns[idx].classList.add(isCorrect ? 'correct' : 'wrong');

  if (isCorrect) {
    const timeBonus = Math.round(timeLeft * 3);
    const streakBonus = quizStreak >= 2 ? (quizStreak * 10) : 0;
    const points = 100 + timeBonus + streakBonus;
    quizScore += points;
    quizStreak++;
    correctAnswers++;
    if (quizStreak > bestQuizStreak) bestQuizStreak = quizStreak;
    showQuizFeedback(true, `✅ Correct! +${points} points${streakBonus > 0 ? ` (${quizStreak}x streak bonus!)` : ''}. ${q.explanation}`);
  } else {
    btns[q.answer].classList.add('reveal');
    quizStreak = 0;
    showQuizFeedback(false, `❌ Not quite! The answer is <strong>${q.options[q.answer]}</strong>. ${q.explanation}`);
  }

  // Update performance tracking for adaptive difficulty
  if (adaptiveDifficulty) {
    updatePerformance(isCorrect, responseTime);
  }

  // Update category stats
  updateCategoryStats(q.category, isCorrect);

  updateQuizStats();
  document.getElementById('nextBtn').className = 'next-btn show';
}

function revealQuizAnswer() {
  const btns = document.querySelectorAll('.option-btn');
  btns.forEach(b => b.disabled = true);
  btns[quizQuestions[currentQuestion].answer].classList.add('reveal');
}

function showQuizFeedback(correct, html) {
  const fb = document.getElementById('feedback');
  fb.className = `feedback ${correct ? 'correct-fb' : 'wrong-fb'} show`;
  document.getElementById('feedbackIcon').textContent = correct ? '🌟' : '📖';
  document.getElementById('feedbackText').innerHTML = html;
}

function nextQuestion() {
  currentQuestion++;
  if (currentQuestion >= quizQuestions.length) {
    endQuizGame();
  } else {
    renderQuizQuestion();
  }
}

function updateQuizStats() {
  document.getElementById('scoreDisplay').textContent = quizScore.toLocaleString();
  document.getElementById('streakDisplay').textContent = quizStreak > 0 ? `${quizStreak}🔥` : quizStreak;
}

function endQuizGame() {
  showScreen('endScreen');
  document.getElementById('progressFill').style.width = '100%';

  const accuracy = Math.round((correctAnswers / quizQuestions.length) * 100);
  document.getElementById('finalScore').textContent = quizScore.toLocaleString();
  document.getElementById('correctCount').textContent = `${correctAnswers}/${quizQuestions.length}`;
  document.getElementById('accuracyPct').textContent = `${accuracy}%`;
  document.getElementById('bestStreak').textContent = bestQuizStreak;

  let trophy, title, rank;
  if (accuracy >= 90) { trophy = '🏆'; title = 'Master Explorer!'; rank = '🌟 Grand Cartographer'; }
  else if (accuracy >= 75) { trophy = '🥇'; title = 'Excellent Work!'; rank = '🗺️ Senior Explorer'; }
  else if (accuracy >= 60) { trophy = '🥈'; title = 'Well Done!'; rank = '🧭 Junior Explorer'; }
  else if (accuracy >= 40) { trophy = '🥉'; title = 'Good Effort!'; rank = '⚓ Apprentice Navigator'; }
  else { trophy = '📜'; title = 'Keep Learning!'; rank = '🌱 Beginner Adventurer'; }

  document.getElementById('trophyEmoji').textContent = trophy;
  document.getElementById('endTitle').textContent = title;
  document.getElementById('rankBadge').textContent = rank;

  // Update progress
  userProgress.totalGamesPlayed++;
  userProgress.totalQuestionsAnswered += quizQuestions.length;
  userProgress.totalCorrectAnswers += correctAnswers;
  
  if (quizScore > userProgress.highestScore) {
    userProgress.highestScore = quizScore;
  }
  
  if (accuracy > userProgress.bestAccuracy) {
    userProgress.bestAccuracy = accuracy;
  }
  
  if (bestQuizStreak > userProgress.longestStreak) {
    userProgress.longestStreak = bestQuizStreak;
  }

  saveProgress();
  checkAchievements();
  updateStatsDisplay();
}

function resetToMenu() {
  showScreen('menuScreen');
  updateStatsDisplay();
}

